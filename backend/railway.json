{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "preDeployCommand": "mkdir -p /app/data && alembic upgrade head && python scripts/seed_users.py && python scripts/seed_tickets.py",
    "startCommand": "/bin/sh -c \"uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}\"",
    "healthcheckPath": "/docs",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
