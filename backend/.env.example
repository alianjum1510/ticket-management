ENVIRONMENT=local
APP_NAME="Ticket Dashboard API"
API_PREFIX=/api
DATABASE_URL=sqlite+aiosqlite:///./app.db
SQL_ECHO=false
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
LOG_LEVEL=INFO
JWT_SECRET_KEY=change-me-generate-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
